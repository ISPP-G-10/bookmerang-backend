{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Matcher": {
    "Weights": {
      "GenreMatch": 0.40,
      "ExtensionMatch": 0.10,
      "DistanceScore": 0.35,
      "RecencyBonus": 0.15
    },
    "Feed": {
      "PriorityToDiscoveryRatio": 3,
      "DefaultPageSize": 20,
      "RecencyDecayDays": 30,
      "SwipeValidDays": 30
    }
  }
}
